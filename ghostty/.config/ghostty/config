# Ghostty config aligned to Wezterm keybindings.
# Note: tab bar location is GTK-only (gtk-tabs-location = bottom).

font-family = "Berkeley Mono"
font-size = 16

cursor-style = block
cursor-style-blink = false
shell-integration-features = no-cursor
copy-on-select = clipboard
clipboard-paste-protection = false
macos-window-buttons = hidden
macos-titlebar-style = tabs
macos-option-as-alt = true
background-opacity = 0.93
background-blur-radius = 20

# Splits (Wezterm: cmd+| for vertical, cmd+- for horizontal)
keybind = cmd+|=new_split:right
keybind = cmd+\=new_split:right
keybind = cmd+shift+\=new_split:right
keybind = cmd+-=new_split:down
keybind = cmd+_=new_split:down
# Match WezTerm split styling.
split-divider-color = #717171
unfocused-split-opacity = 0.6

# Font size
keybind = cmd+shift+minus=decrease_font_size:1
keybind = cmd+_=decrease_font_size:1
keybind = cmd+left_bracket=decrease_font_size:1
keybind = cmd+right_bracket=increase_font_size:1

# Move between splits (Wezterm: cmd+h/j/k/l)
keybind = cmd+h=goto_split:left
keybind = cmd+j=goto_split:down
keybind = cmd+k=goto_split:up
keybind = cmd+l=goto_split:right

# Tabs
keybind = cmd+t=new_tab
keybind = cmd+,=previous_tab
keybind = cmd+.=next_tab
keybind = ctrl+tab=last_tab
keybind = cmd+w=close_tab

# Backward/forward word (send ESC sequences)
keybind = ctrl+b=esc:b
keybind = ctrl+f=esc:f

# Copy-mode alternative: open scrollback in default editor
keybind = alt+c=write_scrollback_file:open

# Fullscreen
keybind = alt+enter=toggle_fullscreen
